{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "运行游戏",
      "type": "process",
      "command": "bevy",
      "args": ["run"],
      "options": {
        "env": {
          "RUST_BACKTRACE": "full"
        }
      },
      "presentation": {
        "clear": true
      },
      "problemMatcher": ["$rustc"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "编译",
      "type": "process",
      "command": "bevy",
      "args": ["build", "--release"],
      "presentation": {
        "clear": true
      },
      "problemMatcher": ["$rustc"],
      "group": "build"
    }
  ]
}
